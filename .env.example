# API Keys for AI Services
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
# Comma-separated Groq API keys for load-balancing / rotating
GROQ_API_KEYS=key1,key2,key3

# Query Rewriter Configurations
QUERY_REWRITER_ENABLED=true
QUERY_REWRITER_API_KEY=your_query_rewriter_api_key_here

# Backend Connection & Configurations
STUDENT_RAG_API_BASE_URL=http://127.0.0.1:8000
STUDENT_RAG_EXECUTION_MODE=API
STUDENT_RAG_SHOW_DEBUG=false
STUDENT_RAG_MAX_QUERY_CHARS=500
STUDENT_RAG_RATE_LIMIT_PER_MINUTE=20
STUDENT_RAG_MAX_CONCURRENT_CHAT=3
STUDENT_RAG_MAX_QUEUE_SIZE=10
STUDENT_RAG_QUEUE_TIMEOUT_SECONDS=15

# Databases URLs (ChromaDB / Qdrant Cloud / MongoDB / Redis Cache)
VECTORDB_PROVIDER=chroma
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key
# Set true only for local migration/admin jobs. Runtime should query only.
QDRANT_CREATE_PAYLOAD_INDEXES=false
MONGODB_URL=mongodb+srv://...
MONGODB_PARENT_LOOKUP_ENABLED=true
MONGODB_TIMEOUT_MS=3000
MONGODB_FAILURE_BACKOFF_SECONDS=300
REDIS_URL=rediss://...

# Observability (Langfuse)
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_HOST="https://jp.cloud.langfuse.com"

# Telemetry
ANONYMIZED_TELEMETRY=False
