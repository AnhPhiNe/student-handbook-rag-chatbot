GEMINI_API_KEY=your_api_key_here
QUERY_REWRITER_ENABLED=false
QUERY_REWRITER_API_KEY=your_query_rewriter_api_key_here
STUDENT_RAG_API_BASE_URL=http://127.0.0.1:8000
STUDENT_RAG_EXECUTION_MODE=Local
STUDENT_RAG_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
STUDENT_RAG_SHOW_DEBUG=false
STUDENT_RAG_MAX_QUERY_CHARS=500
STUDENT_RAG_RATE_LIMIT_PER_MINUTE=20
# Required only for admin-only diagnostics such as /health/artifacts.
# STUDENT_RAG_ADMIN_API_KEY=change_me

# Logging
LOG_LEVEL=INFO

# Vector Database Provider (chroma | qdrant_cloud)
VECTORDB_PROVIDER=chroma
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# Observability (LangSmith)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT="student_handbook_rag"

# Cohere API Key for Cross-Encoder Reranking
COHERE_API_KEY=your_cohere_key_here
